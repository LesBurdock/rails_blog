<%= render partial: "shared/navbar" %>

<!-- Category band -->
<div class="relative py-16 mt-32 mb-16">

  <!-- Background -->
  <div class="absolute inset-0 rounded-bl-[4rem] rounded-tr-[4rem] overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-r from-[hsla(237,17%,21%,0.95)] to-[hsla(237,23%,32%,0.95)]"></div>
    <%= image_tag('bg-pattern-circles.svg', class: 'absolute right-0 top-0 h-full w-1/2 object-cover object-left') %>
    <div class="absolute inset-0 bg-veryDarkGrayBlue/70"></div>
  </div>

  <!-- Tab buttons -->
  <div class="relative z-10 pt-10 px-8 md:px-20">
    <div class="flex gap-10">
      <button class="tab-button pb-4 font-Ubuntu text-lg text-grayishBlue50 transition-all duration-200 focus:outline-none" data-tab="nutrition">Nutrition</button>
      <button class="tab-button pb-4 font-Ubuntu text-lg text-grayishBlue50 transition-all duration-200 focus:outline-none" data-tab="cardio">Cardio</button>
      <button class="tab-button pb-4 font-Ubuntu text-lg text-grayishBlue50 transition-all duration-200 focus:outline-none" data-tab="strength">Strength</button>
    </div>
    <div class="border-t border-white/20"></div>
  </div>

  <!-- Tab content -->
  <div class="relative z-10">

    <div id="nutrition" class="tab-content">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-16 px-8 md:px-20 py-16">
        <div>
          <h3 class="text-4xl md:text-5xl font-Ubuntu text-white leading-tight">Fuel Your Training.<br>Fuel Your Life.</h3>
        </div>
        <div class="flex flex-col justify-center">
          <p class="text-grayishBlue font-light leading-relaxed mb-4">
            What you eat is just as important as how you train. Getting your nutrition right means showing up fuelled — protein to rebuild muscle, carbs for energy, and real food that keeps you consistent without the guilt.
          </p>
          <p class="text-grayishBlue font-light leading-relaxed mb-8">
            Forget perfection. Focus on habits that work with your life: a solid pre-workout meal, enough protein across the day, and hydration that supports recovery.
          </p>
          <%= link_to user_signed_in? ? new_blog_post_path : new_user_session_path,
              class: "self-start border border-white text-white font-medium py-2 px-8 rounded-full hover:bg-white hover:text-veryDarkGrayBlue transition-colors duration-200" do %>
            Share your nutrition story &rarr;
          <% end %>
        </div>
      </div>
    </div>

    <div id="cardio" class="tab-content hidden">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-16 px-8 md:px-20 py-16">
        <div>
          <h3 class="text-4xl md:text-5xl font-Ubuntu text-white leading-tight">Build Your Base.<br>Go the Distance.</h3>
        </div>
        <div class="flex flex-col justify-center">
          <p class="text-grayishBlue font-light leading-relaxed mb-4">
            Cardio and strength training aren't opposites — they're partners. Zone 2 steady-state work builds your aerobic engine, improves recovery between sets, and keeps your heart healthy for the long run.
          </p>
          <p class="text-grayishBlue font-light leading-relaxed mb-8">
            Whether it's a long walk, a morning run, or short HIIT sessions, the key is consistency over intensity. Find what you enjoy, and you'll actually keep doing it.
          </p>
          <%= link_to user_signed_in? ? new_blog_post_path : new_user_session_path,
              class: "self-start border border-white text-white font-medium py-2 px-8 rounded-full hover:bg-white hover:text-veryDarkGrayBlue transition-colors duration-200" do %>
            Share your cardio journey &rarr;
          <% end %>
        </div>
      </div>
    </div>

    <div id="strength" class="tab-content hidden">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-16 px-8 md:px-20 py-16">
        <div>
          <h3 class="text-4xl md:text-5xl font-Ubuntu text-white leading-tight">Lift With Purpose.<br>Get Stronger.</h3>
        </div>
        <div class="flex flex-col justify-center">
          <p class="text-grayishBlue font-light leading-relaxed mb-4">
            Progressive overload is the foundation of getting stronger. You don't need to go heavier every session — adding a rep, improving your form, or reducing rest time all count as progress.
          </p>
          <p class="text-grayishBlue font-light leading-relaxed mb-8">
            Compound movements — squats, deadlifts, rows, presses — give you the most return for your effort. Nail the fundamentals first, and the results will follow.
          </p>
          <%= link_to user_signed_in? ? new_blog_post_path : new_user_session_path,
              class: "self-start border border-white text-white font-medium py-2 px-8 rounded-full hover:bg-white hover:text-veryDarkGrayBlue transition-colors duration-200" do %>
            Share your strength journey &rarr;
          <% end %>
        </div>
      </div>
    </div>

  </div>
</div>

<!-- Page heading -->
<div class="text-center pt-12 pb-10 px-4">
  <h1 class="font-Ubuntu text-4xl md:text-5xl text-veryDarkBlue">Be Inspired</h1>
  <p class="mt-3 font-light text-veryDarkGrayishBlue text-lg">Stories and inspiration from the community</p>
  <div class="mt-6 mx-auto w-16 border-t-2 border-veryLightRed"></div>
</div>

<!-- Alternating post rows -->
<div class="space-y-0">
  <% @blog_posts.each_with_index do |post, index| %>
    <% even = index.even? %>

    <% if post.photo.attached? %>
      <!-- Post with photo: alternating image/text -->
      <div class="grid grid-cols-1 md:grid-cols-[minmax(2rem,1fr)_minmax(0,40rem)_minmax(0,40rem)_minmax(2rem,1fr)] py-12 <%= index < @blog_posts.size - 1 ? 'border-b border-gray-100' : '' %>">
        <div class="hidden md:block"></div>

        <% if even %>
          <!-- Image left, text right -->
          <div class="md:col-start-2">
            <%= link_to post, class: "block w-full h-72 md:h-80 overflow-hidden rounded-md" do %>
              <%= image_tag post.photo, class: "w-full h-full object-cover object-center" %>
            <% end %>
          </div>
          <div class="md:col-start-3 flex flex-col justify-center px-4 md:px-10 pt-6 md:pt-0">
            <h2 class="font-Ubuntu text-2xl md:text-3xl text-veryDarkBlue mb-4"><%= post.title %></h2>
            <p class="font-light text-veryDarkGrayishBlue leading-relaxed mb-6">
              <%= post.extract.present? ? post.extract : truncate(post.content, length: 200) %>
            </p>
            <%= link_to "Read more →", post, class: "self-start border border-textRed text-textRed font-medium py-2 px-6 rounded-full hover:bg-textRed hover:text-white transition-colors duration-200" %>
          </div>
        <% else %>
          <!-- Text left, image right -->
          <div class="md:col-start-2 flex flex-col justify-center px-4 md:px-10 pt-6 md:pt-0 order-2 md:order-1">
            <h2 class="font-Ubuntu text-2xl md:text-3xl text-veryDarkBlue mb-4"><%= post.title %></h2>
            <p class="font-light text-veryDarkGrayishBlue leading-relaxed mb-6">
              <%= post.extract.present? ? post.extract : truncate(post.content, length: 200) %>
            </p>
            <%= link_to "Read more →", post, class: "self-start border border-textRed text-textRed font-medium py-2 px-6 rounded-full hover:bg-textRed hover:text-white transition-colors duration-200" %>
          </div>
          <div class="md:col-start-3 order-1 md:order-2">
            <%= link_to post, class: "block w-full h-72 md:h-80 overflow-hidden rounded-md" do %>
              <%= image_tag post.photo, class: "w-full h-full object-cover object-center" %>
            <% end %>
          </div>
        <% end %>

        <div class="hidden md:block"></div>
      </div>

    <% else %>
      <!-- Post without photo: centered text card -->
      <div class="grid grid-cols-1 md:grid-cols-[minmax(2rem,1fr)_minmax(0,80rem)_minmax(2rem,1fr)] py-12 <%= index < @blog_posts.size - 1 ? 'border-b border-gray-100' : '' %>">
        <div class="hidden md:block"></div>
        <div class="md:col-start-2 px-4 md:px-10">
          <h2 class="font-Ubuntu text-2xl md:text-3xl text-veryDarkBlue mb-4"><%= post.title %></h2>
          <p class="font-light text-veryDarkGrayishBlue leading-relaxed mb-6">
            <%= post.extract.present? ? post.extract : truncate(post.content, length: 300) %>
          </p>
          <%= link_to "Read more →", post, class: "inline-block border border-textRed text-textRed font-medium py-2 px-6 rounded-full hover:bg-textRed hover:text-white transition-colors duration-200" %>
        </div>
        <div class="hidden md:block"></div>
      </div>
    <% end %>

  <% end %>

  <% if @blog_posts.empty? %>
    <div class="text-center py-24">
      <p class="font-light text-veryDarkGrayishBlue text-lg">No posts yet. Be the first to share your journey.</p>
      <%= link_to "Start Sharing", new_blog_post_path, class: "mt-6 inline-block border border-veryDarkBlue text-veryDarkBlue font-medium py-2 px-8 rounded-full hover:bg-veryDarkBlue hover:text-white transition-colors duration-200" %>
    </div>
  <% end %>
</div>
