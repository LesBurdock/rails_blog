<% is_home = current_page?(root_path) %>
<% is_blog_index = current_page?(blog_posts_all_path) %>
<nav class="<%= is_home ? 'absolute' : 'relative' %> top-0 left-0 right-0 z-10 bg-opacity-50 p-8">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between">
      
      <!-- Logo (left on mobile, left on desktop) -->
      <div class="order-1 flex flex-1 justify-start">
         <%= link_to root_path do %>
            <% logo = is_home ? "logo.svg" : is_blog_index ? "logo-dark.svg" : "logo-pink.png" %>
            <%= image_tag(logo, class: is_home ? "h-10" : "h-16") %>
          <% end %>
      </div>

      <!-- Mobile menu button (right side, visible on mobile only) -->
      <div class="sm:hidden order-3">
        <button type="button"
          class="inline-flex items-center justify-center rounded-md p-2
            <%= is_home ? 'text-white' : is_blog_index ? 'text-veryDarkBlue' : 'text-textRed' %>
            focus:outline-none focus:ring-2 focus:ring-inset focus:ring-white"
          aria-controls="mobile-menu" aria-expanded="false" id="mobile-menu-button">
          <span class="sr-only">Open main menu</span>
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
              d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
          </svg>
        </button>
      </div>

      <!-- DESKTOP NAV LINKS + AUTH -->
      <div class="hidden sm:flex sm:items-center sm:space-x-6 order-2">
        <% nav_link_class = is_home ? 'text-white hover:text-grayishBlue50' : is_blog_index ? 'text-veryDarkBlue hover:text-veryDarkGrayishBlue' : 'text-textRed hover:text-veryLightRed' %>
        <%= link_to "Be Inspired", blog_posts_all_path, class: "#{nav_link_class} px-3 py-2" %>
        <%= link_to "Share", new_blog_post_path, class: "#{nav_link_class} px-3 py-2" %>

        <% if user_signed_in? %>
          <!-- Avatar dropdown -->
          <div class="relative flex items-center px-3 py-2">
            <button
              id="user-menu-button"
              type="button"
              class="flex items-center focus:outline-none"
              aria-expanded="false"
            >
              <% if current_user.avatar.attached? %>
                <%= image_tag current_user.avatar.variant(resize_to_fill: [32,32]),
                      class: "h-8 w-8 rounded-full cursor-pointer" %>
              <% else %>
                <%= image_tag "avatar-placeholder1.jpg", class: "h-8 w-8 rounded-full cursor-pointer" %>
              <% end %>
            </button>

            <!-- Dropdown -->
            <div
              id="user-dropdown"
              class="hidden absolute right-0 top-12 w-44 bg-white rounded-xl shadow-lg ring-1 ring-black/5 font-ubuntu z-20 overflow-hidden"
            >
              <%= link_to "Profile", edit_user_registration_path, class: "flex items-center gap-2 px-4 py-3 text-sm text-veryDarkGrayishBlue hover:bg-veryLightRed hover:text-textRed transition-colors" %>
              <%= link_to "New Post", new_blog_post_path, class: "flex items-center gap-2 px-4 py-3 text-sm text-veryDarkGrayishBlue hover:bg-veryLightRed hover:text-textRed transition-colors" %>
              <div class="border-t border-gray-100"></div>
              <%= link_to "Logout", destroy_user_session_path,
                  method: :delete,
                  class: "flex items-center gap-2 px-4 py-3 text-sm text-textRed hover:bg-veryLightRed transition-colors" %>
            </div>
          </div>
        <% else %>
          <%= link_to "Login", new_user_session_path,
              class: "#{nav_link_class} px-3 py-2" %>
          <%= link_to "Sign Up", new_user_registration_path,
              class: "#{is_home ? 'border border-white text-white hover:bg-white hover:text-textRed' : is_blog_index ? 'border border-veryDarkBlue text-veryDarkBlue hover:bg-veryDarkBlue hover:text-white' : 'bg-white hover:bg-veryLightRed text-textRed hover:text-white'} font-medium py-1 px-6 rounded-full" %>
        <% end %>
      </div>
  </div>

  <!-- MOBILE MENU -->
    <div class="sm:hidden hidden" id="mobile-menu">
    <div class="space-y-1 px-2 pb-3 pt-2 bg-veryLightRed">
      <% if user_signed_in? %>
        <div class="flex items-center space-x-2 px-3 py-2 border-b border-gray-200">
          <% if current_user.avatar.attached? %>
            <%= image_tag current_user.avatar.variant(resize_to_fill: [32,32]), class: "h-8 w-8 rounded-full" %>
          <% else %>
            <%= image_tag "avatar-placeholder1.jpg", class: "h-8 w-8 rounded-full" %>
          <% end %>
          <span class="text-gray-50"><%= current_user.email %></span>
        </div>
      <% end %>
      <%= link_to "Get Inspired", blog_posts_all_path, class: "block px-3 py-2 text-gray-300 hover:bg-gray-700 hover:text-white rounded-md" %>
      <%= link_to "Start sharing", new_blog_post_path, class: "block px-3 py-2 text-gray-300 hover:bg-gray-700 hover:text-white rounded-md" %>
      <% if user_signed_in? %>
        <%= link_to "Profile", edit_user_registration_path, class: "block px-3 py-2 text-gray-300 hover:bg-gray-700 hover:text-white rounded-md" %>
        <%= button_to "Logout", destroy_user_session_path, method: :delete, class: "block w-full text-left px-3 py-2 text-gray-300 hover:bg-gray-700 hover:text-white rounded-md bg-transparent border-0" %>
      <% else %>
        <%= link_to "Login", new_user_session_path, class: "block px-3 py-2 text-gray-300 hover:bg-gray-700 hover:text-white rounded-md" %>
        <%= link_to "Sign Up", new_user_registration_path, class: "block px-3 py-2 text-gray-300 hover:bg-gray-700 hover:text-white rounded-md" %>
      <% end %>
    </div>
  </div>
</nav>

